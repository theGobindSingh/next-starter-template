  },
  "private": true,
  "scripts": {
    "prebuild": "pnpm run lint:fix",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "prettier --config .prettierrc \"src/**/*.{ts,js,tsx,jsx}\" --check && eslint \"src/**/*.{ts,js,tsx,jsx}\"",
    "lint:fix": "prettier --config .prettierrc \"src/**/*.{ts,js,tsx,jsx}\" --write && eslint \"src/**/*.{ts,js,tsx,jsx}\" --fix"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@kami-ui/next-theme": "^0.0.22",
    "@kami-ui/react-components": "^0.0.3",
    "@kami-ui/theme-shop": "^0.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@kami-ui/eslint-config": "^0.0.6",
    "@kami-ui/types": "^0.0.3",
    "@tsconfig/next": "^2.0.6",
    "@tsconfig/strictest": "^2.0.8",
    "eslint": "^10.2.0",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "rimraf": "^6.1.3",
    "glob": "^13.0.6"
  },
  "resolutions": {
    "rimraf": "^6.1.3",
    "glob": "^13.0.6"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
