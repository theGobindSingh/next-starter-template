    "typescript": "^5.9.3"
  },
  "overrides": {
    "rimraf": "^6.1.2",
    "glob": "^13.0.0"
  },
  "resolutions": {
    "rimraf": "^6.1.2",
    "glob": "^13.0.0"
  },
  "engines": {
    "node": ">=16"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
